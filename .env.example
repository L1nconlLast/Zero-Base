# Zero Base 2.0 - Variáveis de Ambiente

# Aplicação
VITE_APP_NAME=Zero Base
VITE_APP_VERSION=2.1.0
VITE_PWA_ENABLED=true
VITE_DEV_MODE=true

# Supabase (obrigatório)
# Nunca use SUPABASE_SERVICE_ROLE_KEY no frontend.
VITE_SUPABASE_URL=

# Preferível (chave pública moderna)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Compatibilidade legada (use apenas se não tiver publishable key)
VITE_SUPABASE_ANON_KEY=

# OAuth habilitado na UI (separado por vírgula)
# Exemplo: VITE_SUPABASE_OAUTH_PROVIDERS=google,facebook
# Se vazio, os botões sociais ficam ocultos para evitar redirect para provider desabilitado.
VITE_SUPABASE_OAUTH_PROVIDERS=

# Backend Mentor API
SUPABASE_URL=
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Provedor de IA (padrao sem custo: local)
MENTOR_PROVIDER=local
GEMINI_API_KEY=
MENTOR_GEMINI_MODEL=gemini-2.0-flash

# OpenAI (opcional)
OPENAI_API_KEY=
MENTOR_OPENAI_MODEL=gpt-4o-mini

MENTOR_API_PORT=3001
MENTOR_MAX_DAILY_TOKENS=25000
MENTOR_ALLOW_GUEST=true

# Push notifications web (VAPID)
# Gere as chaves com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:suporte@zerobase.app
PUSH_INACTIVITY_JOB_INTERVAL_MINUTES=60

# Opcional: desligar scheduler automatico em ambientes de teste
PUSH_SCHEDULER_ENABLED=true

# Testes E2E (opcional — necessario para rodar login/logout em producao)
# Crie um usuario confirmado rodando: npx tsx scripts/setup-e2e-user.ts
E2E_LOGIN_EMAIL=
E2E_LOGIN_PASSWORD=

# CHECKLIST DE SEGURANCA ANTES DE DEPLOY
# [ ] NODE_ENV=production
# [ ] MENTOR_ALLOW_GUEST=false
# [ ] Rotacionar qualquer chave que tenha sido exposta
# [ ] Confirmar que .env real nao esta commitado

# Observação para Vercel
# - Configure as mesmas variáveis em Production e Preview.
# - Após alterar env no Vercel, faça novo deploy para aplicar.
