# Medicina do Zero 2.0 - Variáveis de Ambiente

# Vite
VITE_APP_NAME=Medicina do Zero
VITE_APP_VERSION=2.0.0

# PWA
VITE_PWA_ENABLED=true

# Desenvolvimento
VITE_DEV_MODE=true

# Supabase
# DEV: pode usar Confirm email = OFF no Dashboard (Authentication > Providers > Email)
# PROD: Confirm email = ON + SMTP próprio configurado
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Compatibilidade legada (use apenas se não tiver publishable key)
VITE_SUPABASE_ANON_KEY=
