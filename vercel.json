      "path": "/api/notifications/trigger-day1",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/notifications/trigger-day1",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/notifications/trigger-day1",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/notifications/trigger-day1",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/notifications/trigger-day1",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/notifications/trigger-day1",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/notifications/trigger-day1",
      "schedule": "0 15 * * *"
    },
    {
      "path": "/api/notifications/trigger-day1",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/notifications/trigger-day1",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/notifications/trigger-day1",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/notifications/trigger-day1",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/notifications/trigger-day1",
