      "schedule": "0 23 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/notifications/public-key",
      "destination": "/api/notifications?action=public-key"
    },
    {
      "source": "/api/notifications/subscribe",
      "destination": "/api/notifications?action=subscribe"
    },
    {
      "source": "/api/notifications/unsubscribe",
      "destination": "/api/notifications?action=unsubscribe"
    },
    {
      "source": "/api/notifications/heartbeat",
      "destination": "/api/notifications?action=heartbeat"
    },
    {
      "source": "/api/notifications/test",
      "destination": "/api/notifications?action=test"
    },
    {
      "source": "/api/notifications/trigger-day1",
      "destination": "/api/notifications?action=trigger-day1"
    },
    {
      "source": "/api/study-sessions/:sessionId/answer",
      "destination": "/api/study-session-router?sessionId=:sessionId&action=answer"
    },
    {
      "source": "/api/study-sessions/:sessionId/finish",
      "destination": "/api/study-session-router?sessionId=:sessionId&action=finish"
    },
    {
      "source": "/api/study-sessions/:sessionId",
      "destination": "/api/study-session-router?sessionId=:sessionId"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(sw.js|registerSW.js|manifest.webmanifest)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ]
}
