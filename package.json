{
  "name": "zero-base",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "mentor:server": "tsx server/src/index.ts",
    "mentor:workers": "tsx server/src/index.ts",
    "ai:service": "cd ai-service && python -m uvicorn app.main:app --host 0.0.0.0 --port 8001 --reload",
    "build": "tsc && vite build",
    "knowledge-graph:build": "tsx scripts/generate-knowledge-graph-seed.ts",
    "knowledge-graph:promote": "tsx scripts/promote-knowledge-graph-seed-to-migration.ts",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "test": "npm run test:client && npm run test:server",
    "test:client": "vitest run --exclude server/src/tests/**",
    "test:server": "vitest run --config server/vitest.config.ts",
    "test:server:watch": "vitest --config server/vitest.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:verify": "cypress verify",
    "e2e": "start-server-and-test dev http://localhost:5173 cy:run",
    "e2e:open": "start-server-and-test dev http://localhost:5173 cy:open",
    "test:all": "npm test -- --run && npm run e2e",
    "setup:e2e": "tsx scripts/setup-e2e-user.ts"
  },
  "dependencies": {
    "@sentry/browser": "^10.40.0",
    "@sentry/node": "^10.43.0",
    "@supabase/supabase-js": "^2.97.0",
    "@xyflow/react": "^12.10.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "date-fns": "^3.2.0",
    "dompurify": "^3.0.9",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.10.0",
    "jose": "^5.10.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.344.0",
    "node-cache": "^5.1.2",
    "openai": "^6.27.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "recharts": "^2.12.0",
    "secure-ls": "^2.0.0",
    "supertest": "^7.2.2",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/dompurify": "^3.0.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@types/supertest": "^7.2.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.18",
    "cypress": "^15.11.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.35",
    "start-server-and-test": "^2.1.5",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^0.19.0",
    "vitest": "^4.0.18"
  }
}
